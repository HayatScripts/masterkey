local function redeemKey(inputKey)
    local masterKeys = fetchMasterKeys()
    
    if not masterKeys then
        return false, "Error: Could not connect to GitHub"
    end

    -- Loop through your GitHub list to see if the key exists
    local found = false
    for _, validKey in ipairs(masterKeys) do
        if inputKey == validKey then
            found = true
            break
        end
    end

    if found then
        -- Key is valid, save it for next time
        if writefile then 
            writefile(Config.KeyFileName, inputKey) 
        end
        return true, "Success"
    else
        -- Key was either deleted from GitHub or never existed
        return false, "Invalid or Expired Key"
    end
end

