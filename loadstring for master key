local function StartSecurityHeartbeat(keyUsed)
    task.spawn(function()
        while isVerified do
            task.wait(60) -- Checks every 60 seconds
            local stillValid, _ = isKeyInList(keyUsed)
            if not stillValid then
                print("[CHICKENHUB] Access Revoked Remotely.")
                isVerified = false
                local pGui = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
                if pGui and pGui:FindFirstChild(Config.MainGuiName) then 
                    pGui[Config.MainGuiName]:Destroy() 
                end
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "Access Revoked",
                    Text = "The owner has disabled this key.",
                    Duration = 10
                })
                break
            end
        end
    end)
end

