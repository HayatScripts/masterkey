-------------------------------------------------------------------------------

local function fetchMasterKeys()
    print("[CHICKENHUB] Fetching database...")
    local success, result = pcall(function()
        -- Adding os.time() prevents GitHub from showing old/cached versions of your keys
        return game:HttpGet(Config.GitHubKeyURL .. "?t=" .. os.time()) 
    end)
    
    if success then
        print("[CHICKENHUB] Connected to GitHub.")
        local keys = {}
        for line in result:gmatch("[^\r\n]+") do
            local cleanKey = line:gsub("%s+", "")
            if cleanKey ~= "" then
                table.insert(keys, cleanKey)
            end
        end
        return keys
    else
        warn("[CHICKENHUB] Error fetching keys: " .. tostring(result))
        return nil
    end
end

local function isKeyInList(inputKey)
    local masterKeys = fetchMasterKeys()
    if not masterKeys then return false, "Connection Error" end
    for _, validKey in ipairs(masterKeys) do
        if inputKey == validKey then
            return true, "Success"
        end
    end
    return false, "Invalid or Expired Key"
end

